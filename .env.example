# ============================================================================
# NEXUS-AGI — Master Environment Configuration
# ============================================================================
# Copy to .env and fill in your values:  cp .env.example .env
# This single file is used by ALL NEXUS services.
# ============================================================================

# ── CORE ─────────────────────────────────────────────────────────────────────
NEXUS_ENV=production

# ── LLM PROVIDERS ────────────────────────────────────────────────────────────
# Required: at least one of these
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: enables cheaper model tiers
GEMINI_API_KEY=your-google-gemini-key
GOOGLE_API_KEY=your-google-api-key
DEEPSEEK_API_KEY=your-deepseek-key
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...

# ── AGENT ZERO (Primary UI Shell) ─────────────────────────────────────────
WEB_UI_PORT=50001
WEB_UI_HOST=0.0.0.0

# ── UNIFIED LLM ROUTER ────────────────────────────────────────────────────
LLM_ROUTER_URL=http://localhost:8091

# ── UNIFIED COST/BUDGET TRACKER ──────────────────────────────────────────
COST_TRACKER_URL=http://localhost:8092
DAILY_BUDGET_USD=5.00
MONTHLY_BUDGET_USD=20.00
PER_RUN_BUDGET_USD=1.00

# ── CLAUDE CODE ADAPTER SERVICE ──────────────────────────────────────────
CLAUDE_ADAPTER_HOST=0.0.0.0
CLAUDE_ADAPTER_PORT=8090
CLAUDE_ADAPTER_API_KEY=change-me-to-a-long-random-string
CLAUDE_ADAPTER_WORKDIR=/home/ubuntu/Nexus-AGI
CLAUDE_ADAPTER_MAX_TURNS=25
CLAUDE_ADAPTER_CORS_ORIGINS=http://localhost:50001,http://127.0.0.1:50001
CLAUDE_ADAPTER_URL=http://localhost:8090
CLAUDE_ADAPTER_TIMEOUT=300

# ── REDIS ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LINKEDIN BOT ─────────────────────────────────────────────────────────
LLM_MODEL=anthropic/claude-3-haiku
LINKEDIN_BOT_URL=http://localhost:8083
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me

# ── LEAD GEN SERVICE ─────────────────────────────────────────────────────
LEAD_GEN_PORT=8082
LEAD_GEN_URL=http://localhost:8082
LEAD_GEN_DB_URL=sqlite:///./lead_gen.db
APOLLO_API_KEY=your-apollo-api-key

# ── POLYMARKET TRADING ───────────────────────────────────────────────────
TRADING_SERVICE_URL=http://localhost:8000
TRADING_WATCHLIST=AAPL,MSFT,SPY
TRADING_ENABLE_PAPER_TRADING=0
TRADING_STRATEGY=day
EXECUTION_BROKER=paper
IBKR_HOST=127.0.0.1
IBKR_PORT=7497

# ── ELEVENLABS VOICE (Agent Zero extensions) ─────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-voice-id
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── CLAUDE CODE CLI ──────────────────────────────────────────────────────
CLAUDE_CODE_CLI_PATH=claude

# ── NEMOTRON (via OpenRouter) ────────────────────────────────────────────
NEMOTRON_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# ── LANGSMITH (Optional) ─────────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=nexus-agi

# ── TWILIO (Deferred) ───────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_PHONE_NUMBER=+1234567890

# ── CRYPTO (Future) ─────────────────────────────────────────────────────
# BINANCE_API_KEY=your-key
# BINANCE_SECRET_KEY=your-key
