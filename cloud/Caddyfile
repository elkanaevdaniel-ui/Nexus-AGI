nexus-elkana.duckdns.org {

    # Security Headers
    header {
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' wss: ws:; font-src 'self'"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-XSS-Protection "1; mode=block"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # Rate Limiting (requires caddy-ratelimit plugin)
    # If caddy-ratelimit is installed, uncomment:
    # rate_limit {remote.ip} 100r/m

    # Agent Zero — Primary UI
    handle /ws {
        reverse_proxy localhost:50001
    }
    handle /agent-zero/* {
        reverse_proxy localhost:50001
    }

    # LLM Router
    handle /api/llm/* {
        reverse_proxy localhost:5100 {
            health_uri /health
            health_interval 30s
            health_timeout 5s
        }
    }

    # Cost Tracker
    handle /api/costs/* {
        reverse_proxy localhost:5200 {
            health_uri /health
            health_interval 30s
            health_timeout 5s
        }
    }

    # Claude Adapter
    handle /api/claude/* {
        reverse_proxy localhost:5300 {
            health_uri /health
            health_interval 30s
            health_timeout 5s
        }
    }

    # Trading API
    handle /api/trading/* {
        reverse_proxy localhost:8000 {
            health_uri /health
            health_interval 30s
            health_timeout 5s
        }
    }

    # LinkedIn Dashboard
    handle /dashboard/* {
        reverse_proxy localhost:7860
    }

    # Lead Gen Frontend
    handle /leads/* {
        reverse_proxy localhost:3000
    }

    # Lead Gen API
    handle /api/leads/* {
        reverse_proxy localhost:3001
    }

    # Health Check Endpoint
    handle /health {
        respond "OK" 200
    }

    # Default -> Agent Zero
    handle {
        reverse_proxy localhost:50001
    }
}
